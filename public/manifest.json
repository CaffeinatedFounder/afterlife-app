  "shortcuts": [
    {
      "name": "Create Will",
      "short_name": "New Will",
      "description": "Start creating your digital will",
      "url": "/dashboard/will/create",
      "icons": [
        {
          "src": "/shortcut-will.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "View Beneficiaries",
      "short_name": "Beneficiaries",
      "description": "View and manage your beneficiaries",
      "url": "/dashboard/beneficiaries",
      "icons": [
        {
          "src": "/shortcut-beneficiaries.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Vault",
      "short_name": "Vault",
      "description": "Access your document vault",
      "url": "/dashboard/vault",
      "icons": [
        {
          "src": "/shortcut-vault.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Messages",
      "short_name": "Messages",
      "description": "Leave messages for your loved ones",
      "url": "/dashboard/messages",
      "icons": [
        {
          "src": "/shortcut-messages.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "image/*",
            "application/pdf",
            "application/msword",
            ".doc",
            ".docx",
            ".pdf"
          ]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/vault/upload",
      "accept": {
        "application/pdf": [".pdf"],
        "image/*": [".png", ".jpg", ".jpeg", ".gif", ".webp"],
        "application/msword": [".doc"],
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document": [".docx"]
      },
      "launch_type": "single-client"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": []
}
